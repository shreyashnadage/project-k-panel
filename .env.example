# Phase 0-3: Environment Variables
# Copy this to .env.local and fill in your values
# DO NOT commit .env.local to Git

# Tally Configuration
TALLY_URL=http://localhost:9000
TALLY_COMPANY_NAME=Sharma Traders Pvt Ltd
TALLY_COMPANY_GUID=your-company-guid-here
TALLY_DEVANAGARI_COMPANY=शर्मा ट्रेडर्स

# Cloud Ingest API
INGEST_API_URL=https://api.yourplatform.in
INGEST_API_KEY=your-api-key-here
TENANT_ID=your-tenant-id-here

# Optional: For local development
PYTHONPATH=.
DEBUG=false
