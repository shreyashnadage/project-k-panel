{
  "version": "8.13.0",
  "objects": [
    {
      "type": "dashboard",
      "id": "authorization-overview",
      "attributes": {
        "title": "Authorization Overview - Real-Time Monitoring",
        "description": "Real-time monitoring of authorization decisions across the system",
        "version": 1,
        "refreshInterval": {
          "pause": false,
          "value": 10000
        },
        "timeRestore": true,
        "timeFrom": "now-24h",
        "timeTo": "now",
        "panels": [
          {
            "version": "8.13.0",
            "type": "visualization",
            "gridData": {
              "x": 0,
              "y": 0,
              "w": 12,
              "h": 15
            },
            "id": "auth-decisions-timeline"
          },
          {
            "version": "8.13.0",
            "type": "visualization",
            "gridData": {
              "x": 12,
              "y": 0,
              "w": 12,
              "h": 15
            },
            "id": "auth-allow-deny-pie"
          },
          {
            "version": "8.13.0",
            "type": "visualization",
            "gridData": {
              "x": 0,
              "y": 15,
              "w": 24,
              "h": 10
            },
            "id": "auth-top-denied-permissions"
          },
          {
            "version": "8.13.0",
            "type": "visualization",
            "gridData": {
              "x": 0,
              "y": 25,
              "w": 24,
              "h": 10
            },
            "id": "auth-by-role"
          }
        ]
      }
    },
    {
      "type": "visualization",
      "id": "auth-decisions-timeline",
      "attributes": {
        "title": "Authorization Decisions Timeline",
        "visState": {
          "title": "Authorization Decisions Timeline",
          "type": "line",
          "aggs": [
            {
              "id": "1",
              "enabled": true,
              "type": "count",
              "schema": "metric",
              "params": {}
            },
            {
              "id": "2",
              "enabled": true,
              "type": "date_histogram",
              "schema": "segment",
              "params": {
                "field": "timestamp",
                "interval": "1m"
              }
            }
          ]
        }
      }
    },
    {
      "type": "visualization",
      "id": "auth-allow-deny-pie",
      "attributes": {
        "title": "Allow vs Deny Distribution",
        "visState": {
          "title": "Allow vs Deny Distribution",
          "type": "pie",
          "aggs": [
            {
              "id": "1",
              "enabled": true,
              "type": "count",
              "schema": "metric",
              "params": {}
            },
            {
              "id": "2",
              "enabled": true,
              "type": "terms",
              "schema": "segment",
              "params": {
                "field": "allowed",
                "size": 10
              }
            }
          ]
        }
      }
    },
    {
      "type": "visualization",
      "id": "auth-top-denied-permissions",
      "attributes": {
        "title": "Top Denied Permissions",
        "visState": {
          "title": "Top Denied Permissions",
          "type": "table",
          "aggs": [
            {
              "id": "1",
              "enabled": true,
              "type": "count",
              "schema": "metric",
              "params": {}
            },
            {
              "id": "2",
              "enabled": true,
              "type": "terms",
              "schema": "bucket",
              "params": {
                "field": "action",
                "size": 10
              }
            }
          ]
        }
      }
    },
    {
      "type": "visualization",
      "id": "auth-by-role",
      "attributes": {
        "title": "Authorization Checks by Role",
        "visState": {
          "title": "Authorization Checks by Role",
          "type": "bar",
          "aggs": [
            {
              "id": "1",
              "enabled": true,
              "type": "count",
              "schema": "metric",
              "params": {}
            },
            {
              "id": "2",
              "enabled": true,
              "type": "terms",
              "schema": "segment",
              "params": {
                "field": "role",
                "size": 10
              }
            }
          ]
        }
      }
    }
  ]
}
