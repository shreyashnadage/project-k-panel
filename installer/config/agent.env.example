# Tally Sync Agent — configuration
# Most settings are auto-configured by the registration wizard.
# Only edit this file if you need manual overrides.

# ── Cloud platform (set by registration wizard — leave blank if registered) ──
# CLOUD_URL=http://15.206.90.21:8000
# AGENT_API_KEY=
# AGENT_DEVICE_ID=
# AGENT_TENANT_ID=

# ── Tally connection ─────────────────────────────────────────────────────────
TALLY_URL=http://localhost:9000

# Path to TallyAPIConnectorV2.0.exe (bundled with installer by default)
# Only set this if you moved the connector to a different location.
# TALLY_CONNECTOR_EXE_PATH=

# Set to 1 to auto-launch TallyPrime if not running
AUTO_LAUNCH_TALLY=0

# ── Sync settings ────────────────────────────────────────────────────────────
POLL_INTERVAL=15

# ── Telemetry (error reporting via Sentry) ───────────────────────────────────
# Set your Sentry DSN to enable crash/error reporting back to the platform.
# Leave blank to disable all telemetry — no data leaves the machine.
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=production
